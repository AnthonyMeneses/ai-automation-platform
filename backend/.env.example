# --- Server ---
NODE_ENV=development
PORT=3000
# Public URL of this backend (Twilio signature validation depends on it)
PUBLIC_BASE_URL=http://localhost:3000
# Origin allowed for CORS + auth cookies
FRONTEND_URL=http://localhost:5173
# strict (default) | lax | none — use "none" only if the frontend and backend
# are on different sites (e.g. *.vercel.app + *.railway.app); prefer subdomains
# of one custom domain so "strict" works.
COOKIE_SAMESITE=strict
LOG_LEVEL=info
# Optional: write daily-rotated log files (7 kept) instead of stdout
# LOG_DIR=/var/log/ai-automation

# --- Database (Supabase: Settings -> Database -> Connection string) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/saas_db
# Set to true for Supabase / any managed Postgres
DATABASE_SSL=false

# --- Auth ---
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# --- Anthropic ---
ANTHROPIC_API_KEY=
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_COMPLEX_MODEL=claude-fable-5
# Set to false to run everything on the default (cheaper) model
CLAUDE_ENABLE_COMPLEX_MODEL=true

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs per plan tier (Stripe Dashboard -> Products -> Pricing).
# Required to generate a checkout link for that tier.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Where Stripe redirects after checkout / billing-portal (default to FRONTEND_URL).
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_BILLING_PORTAL_RETURN_URL=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Payroll ---
# Generate with: openssl rand -hex 32
PAYROLL_ENCRYPTION_KEY=
# Generate with: openssl rand -hex 32
PAYROLL_SIGNING_SECRET=
# true returns sample payroll data when a client has no stored credentials
# (defaults to true outside production)
PAYROLL_USE_MOCK=true
ADP_CLIENT_ID=
ADP_CLIENT_SECRET=
GUSTO_API_TOKEN=

# --- Admin bootstrap (used only by scripts/create-admin.js and scripts/seed.js) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Notifications (optional Slack/Zapier-style webhook for failed payments etc.) ---
ADMIN_NOTIFY_WEBHOOK_URL=
